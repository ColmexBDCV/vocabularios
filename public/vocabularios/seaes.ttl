@prefix seaes: <https://biblioteca.colmex.mx/vocabularios/seaes#> .

<https://biblioteca.colmex.mx/vocabularios/seaes>
  a skos:ConceptScheme ;
  dcterms:title "Vocabulario SEAES"@es ;
  dcterms:issued "2026-06-29" ;
  dcterms:publisher "CID_BIBLIOTECA_COLMEX" ;
  dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
  dcterms:description "Vocabulario para registrar criterios del Sistema de Evaluación y Acreditación de la Educación Superior (SEAES) asociados a tesis y trabajos de investigación."@es ;
  skos:prefLabel "Criterios SEAES"@es ;
  skos:hasTopConcept
    seaes:compromiso_responsabilidad_social,
    seaes:equidad_social_genero,
    seaes:inclusion,
    seaes:excelencia,
    seaes:innovacion_social,
    seaes:vanguardia,
    seaes:interculturalidad .

seaes:criterio_seaes
  a rdf:Property ;
  rdfs:label "Criterio SEAES"@es ;
  rdfs:comment "Registra el criterio SEAES con el que una tesis se correlaciona."@es ;
  dcterms:description "Registra el criterio SEAES con el que una tesis se correlaciona."@es ;
  rdfs:isDefinedBy <https://biblioteca.colmex.mx/vocabularios/seaes> .

seaes:justificacion_seaes
  a rdf:Property ;
  rdfs:label "Justificación SEAES"@es ;
  rdfs:comment "Registra la justificación breve de la correlación entre una tesis y el criterio SEAES seleccionado."@es ;
  dcterms:description "Registra la justificación breve de la correlación entre una tesis y el criterio SEAES seleccionado."@es ;
  rdfs:isDefinedBy <https://biblioteca.colmex.mx/vocabularios/seaes> .

seaes:seaes
  a rdf:Property ;
  rdfs:label "SEAES"@es ;
  rdfs:comment "Registra en una sola expresión el criterio SEAES y su justificación."@es ;
